# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual keys.

BRAVE_API_KEY=your_brave_search_api_key_here

# URL of the Ollama server. Defaults to http://localhost:11434 (Ollama's default
# local address). Override when Ollama runs on a different host or port — e.g.
# on a NAS or a GPU server on the same LAN.
# Note: Ollama's own OLLAMA_HOST env var (host:port, no scheme) controls where
# the server binds; this variable is the client-side URL our backend connects to.
OLLAMA_BASE_URL=http://localhost:11434
