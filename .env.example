# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual keys.

BRAVE_API_KEY=your_brave_search_api_key_here

# OLLAMA_BASE_URL — optional override, leave commented out for the common case.
#
# Docker path (docker compose up): defaults to http://host.docker.internal:11434
#   — this reaches the native Ollama process on the Mac host from inside the container.
# Direct path (uv run uvicorn ...): defaults to http://localhost:11434
#   — Ollama's default local address.
#
# Only set this when Ollama is running on a different host (e.g. a GPU server
# or NAS on your LAN). Setting it to http://localhost:11434 here breaks the
# Docker path — inside the container, localhost is the container, not your Mac.
#
# Note: Ollama's own OLLAMA_HOST env var (host:port, no scheme) controls where
# the Ollama server binds; OLLAMA_BASE_URL is the client URL our backend uses.
#
# OLLAMA_BASE_URL=http://192.168.1.100:11434
